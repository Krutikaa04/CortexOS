# CortexOS environment configuration.
# Copy to .env for local Docker development. The SAME variables drive
# production (Render) — only their values differ. Nothing assumes Docker
# networking; every host/URL is overridable.

# --- Database ---
# Local Docker: the compose service name resolves on the internal network.
# Production: a full managed-Postgres URL (postgres:// or postgresql://) works
# as-is — the scheme is normalized and libpq-only params (sslmode, …) are
# translated to a TLS connection automatically.
CORTEX_DB_PASSWORD=change-me
CORTEX_DB_URL=postgresql+asyncpg://cortex:change-me@cortex-db:5432/cortex
# TLS to the database: auto | true | false (auto = infer from URL / prod host)
CORTEX_DB_SSL=auto
CORTEX_DB_POOL_SIZE=5
CORTEX_DB_MAX_OVERFLOW=10

# --- Model provider (Objective 10) ---
# Selects the ModelProvider implementation. "ollama" is the default local,
# zero-cost runtime. Only the provider talks to Ollama; the Kernel does not.
CORTEX_MODEL_PROVIDER=ollama
# Local Docker: the Ollama service name. Production: an Ollama-compatible
# endpoint reachable from the backend (Ollama is NOT deployed to Render).
CORTEX_MODEL_BASE_URL=http://cortex-model:11434
CORTEX_TASK_MODEL=qwen2.5:3b-instruct
CORTEX_EMBED_MODEL=nomic-embed-text
CORTEX_EMBED_DIM=768
# Provider resilience (seconds / attempts)
CORTEX_MODEL_CONNECT_TIMEOUT=10
CORTEX_MODEL_GENERATE_TIMEOUT=600
CORTEX_MODEL_EMBED_TIMEOUT=300
CORTEX_MODEL_MAX_RETRIES=1

# --- Runtime ---
CORTEX_ENV=dev            # dev | production
CORTEX_LOG_LEVEL=INFO
# Optional shared bearer token for the API; empty = no auth (local dev only)
CORTEX_API_TOKEN=
# Browser origins allowed to call the API (comma-separated exact origins),
# e.g. https://your-studio.vercel.app. Empty in dev reflects any origin;
# empty in production means same-origin only.
CORTEX_ALLOWED_ORIGINS=

# Optional token for cloning PRIVATE https git repositories (e.g. a GitHub PAT
# with 'repo' scope). Injected into the clone URL at fetch time; never logged
# or returned by the API. Empty = public repositories only.
CORTEX_GIT_TOKEN=

# --- Worker / storage ---
# Job kinds this worker claims (its lane); empty = claim everything.
CORTEX_WORKER_KINDS=
# Ingestion workspace (writable path). Docker: a named volume. Production: a
# mounted disk or an ephemeral dir when cleanup is enabled.
CORTEX_INGEST_DIR=/data/ingest
# Delete each repo's clone after ingestion (data persists in Postgres).
# Recommended true on ephemeral cloud disks; false locally for fast re-ingest.
CORTEX_INGEST_CLEANUP=false

# --- Frontend (Studio) ---
# Set in the frontend host (Vercel), not here: the backend base URL.
# NEXT_PUBLIC_CORTEX_API_URL=https://cortex-api.onrender.com
